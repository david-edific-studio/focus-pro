{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions pour Focus Pro",
  "windows": ["main", "projection"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "shell:default",
    "asset:default",
    {
      "identifier": "asset:allow-asset",
      "preference": {
        "schemes": ["http", "https"],
        "domains": ["asset.localhost"]
      }
    }
  ]
}